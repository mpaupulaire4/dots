AddKeysToAgent yes

Host *
    ControlMaster auto
    ControlPath /tmp/ssh-%r@%h:%p
    ControlPersist 60
Host 192.168.0.4
    HostKeyAlgorithms +ssh-rsa
    PubkeyAcceptedAlgorithms +ssh-rsa
Host 192.168.0.5
    HostKeyAlgorithms +ssh-rsa
    PubkeyAcceptedAlgorithms +ssh-rsa
Host skygit
    HostName skyvault.lan
    port 2222
    IdentityFile ~/.ssh/id_ed25519
